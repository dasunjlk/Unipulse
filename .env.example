# UniPulse — environment (copy to `.env.local`)

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# n8n webhooks (use ngrok URL in dev)
N8N_BASE_URL=https://your-ngrok-url.ngrok.io
N8N_SHARED_SECRET=generate_a_long_random_string

# Seed admin (must match seed.sql if using default)
SEED_ADMIN_EMAIL=admin@unipulse.local
SEED_ADMIN_PASSWORD=ChangeMe_SeedAdmin123
